{
  "filename": "",
  "groups": [
    {
      "id": "rezolus",
      "name": "Rezolus",
      "plots": [
        {
          "data": [],
          "opts": {
            "description": "The amount of CPU time Rezolus was executing",
            "format": {
              "log_scale": null,
              "precision": 2,
              "range": {
                "max": 1.0,
                "min": 0.0
              },
              "unit_system": "percentage",
              "value_label": null,
              "x_axis_label": null,
              "y_axis_label": null
            },
            "id": "cpu",
            "title": "CPU %",
            "type": "delta_counter"
          },
          "promql_query": "sum(irate(rezolus_cpu_usage[5m])) / 1000000000"
        },
        {
          "data": [],
          "opts": {
            "description": "The total amount of memory allocated by Rezolus",
            "format": {
              "log_scale": null,
              "precision": 2,
              "unit_system": "bytes",
              "value_label": null,
              "x_axis_label": null,
              "y_axis_label": null
            },
            "id": "memory",
            "title": "Memory (RSS)",
            "type": "gauge"
          },
          "promql_query": "sum(rezolus_memory_usage_resident_set_size)"
        },
        {
          "data": [],
          "opts": {
            "description": "The number of instructions retired on a per-cgroup basis",
            "format": {
              "log_scale": null,
              "precision": 2,
              "unit_system": "count",
              "value_label": null,
              "x_axis_label": null,
              "y_axis_label": null
            },
            "id": "ipc",
            "title": "IPC",
            "type": "delta_counter"
          },
          "promql_query": "sum(irate(cgroup_cpu_instructions{name=\"/system.slice/rezolus.service\"}[5m])) / sum(irate(cgroup_cpu_cycles{name=\"/system.slice/rezolus.service\"}[5m]))"
        },
        {
          "data": [],
          "opts": {
            "description": "The number of syscalls on a per-cgroup basis",
            "format": {
              "log_scale": null,
              "precision": 2,
              "unit_system": "rate",
              "value_label": null,
              "x_axis_label": null,
              "y_axis_label": null
            },
            "id": "syscalls",
            "title": "Syscalls",
            "type": "delta_counter"
          },
          "promql_query": "sum(irate(cgroup_syscall{name=\"/system.slice/rezolus.service\"}[5m]))"
        },
        {
          "data": [],
          "opts": {
            "description": "The amount of time Rezolus BPF programs have been executing",
            "format": {
              "log_scale": null,
              "precision": 2,
              "unit_system": "count",
              "value_label": null,
              "x_axis_label": null,
              "y_axis_label": null
            },
            "id": "bpf-overhead",
            "title": "Total BPF Overhead",
            "type": "delta_counter"
          },
          "promql_query": "sum(irate(rezolus_bpf_run_time[5m])) / 1000000000"
        },
        {
          "data": [],
          "opts": {
            "description": "The amount of time Rezolus BPF programs have been executing",
            "format": {
              "log_scale": null,
              "precision": 2,
              "unit_system": "count",
              "value_label": null,
              "x_axis_label": null,
              "y_axis_label": null
            },
            "id": "bpf-sampler-overhead",
            "title": "BPF Per-Sampler Overhead",
            "type": "delta_counter"
          },
          "promql_query": "sum by (sampler) (irate(rezolus_bpf_run_time[5m])) / 1000000000"
        },
        {
          "data": [],
          "opts": {
            "description": "The number of times Rezolus BPF programs have been run",
            "format": {
              "log_scale": null,
              "precision": 2,
              "unit_system": "time",
              "value_label": null,
              "x_axis_label": null,
              "y_axis_label": null
            },
            "id": "bpf-execution-time",
            "title": "BPF Per-Sampler Execution Time",
            "type": "delta_counter"
          },
          "promql_query": "(sum by (sampler) (irate(rezolus_bpf_run_time[5m])) / sum by (sampler) (irate(rezolus_bpf_run_count[5m]))) / 1000000000"
        }
      ]
    }
  ],
  "interval": 0.0,
  "num_series": 0,
