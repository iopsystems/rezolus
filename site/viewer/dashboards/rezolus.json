            "style": "line",
            "title": "Total BPF Overhead"
          },
          "promql_query": "sum(irate(rezolus_bpf_run_time[5m])) / 1000000000"
        },
        {
          "data": [],
          "opts": {
            "format": {
              "log_scale": null,
              "precision": 2,
              "unit_system": "count",
              "value_label": null,
              "x_axis_label": null,
