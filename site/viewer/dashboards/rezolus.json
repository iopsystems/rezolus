          },
          "promql_query": "sum(irate(cgroup_syscall{name=\"/system.slice/rezolus.service\"}[5m]))"
        },
        {
          "data": [],
          "opts": {
            "format": {
              "log_scale": null,
              "precision": 2,
              "unit_system": "count",
              "value_label": null,
              "x_axis_label": null,
              "y_axis_label": null
            },
