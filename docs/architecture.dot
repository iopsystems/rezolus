// Rezolus — what you can do with it (user's view)
//
// Render:  dot -Tsvg docs/architecture.dot -o docs/architecture.svg
//          dot -Tpng docs/architecture.dot -o docs/architecture.png
//
// Everything below is the one `rezolus` binary — you just pick the
// subcommand for the job. Arrows read as "what you do next".

digraph rezolus {
  rankdir=TB;
  fontname="Helvetica";
  nodesep=0.5;
  ranksep=0.75;
  bgcolor="white";

  node [fontname="Helvetica", fontsize=14, shape=box, style="rounded,filled", penwidth=1.4, margin="0.22,0.14"];
  edge [fontname="Helvetica", fontsize=12, color="#607d8b"];

  // ---- What you're watching --------------------------------------------
  system [label=<<b>Your systems</b><br/><font point-size="11">CPU · GPU · kernel · scheduler<br/>syscalls · block I/O · network<br/>containers · services</font>>,
          fillcolor="#e8f5e0", color="#7cb342"];

  // ---- The always-on collector -----------------------------------------
  agent [label=<<b>rezolus agent</b><br/><font point-size="11">always-on collector</font>>,
         fillcolor="#bbdefb", color="#1976d2", penwidth=1.8];

  // ---- Live: stream and watch ------------------------------------------
  exporter [label=<<b>rezolus exporter</b><br/><font point-size="11">Prometheus metrics endpoint</font>>, fillcolor="#e3f2fd", color="#1976d2", group="gExp"];
  view     [label=<<b>rezolus view</b><br/><font point-size="11">interactive dashboard</font>>,     fillcolor="#e3f2fd", color="#1976d2", group="gView"];

  // ---- Capture to a file -----------------------------------------------
  record    [label=<<b>rezolus record</b><br/><font point-size="11">save a recording</font>>,                 fillcolor="#e3f2fd", color="#1976d2"];
  hindsight [label=<<b>rezolus hindsight</b><br/><font point-size="11">go back in time<br/>after an incident</font>>, fillcolor="#e3f2fd", color="#1976d2", group="gRec"];

  // ---- Work with recordings --------------------------------------------
  mcp     [label=<<b>rezolus mcp</b><br/><font point-size="11">AI-guided analysis</font>>,          fillcolor="#e3f2fd", color="#1976d2"];
  pqtools [label=<<b>rezolus parquet</b><br/><font point-size="11">inspect · annotate · combine</font>>, fillcolor="#e3f2fd", color="#1976d2"];

  // ---- The recording artifact ------------------------------------------
  recording [label=<<b>Recording</b><br/><font point-size="11">.parquet file</font>>,
             shape=cylinder, fillcolor="#ffe0b2", color="#f57c00", group="gRec"];

  // ---- Where the value lands -------------------------------------------
  grafana [label=<<b>Prometheus / Grafana</b>>, fillcolor="#eceff1", color="#90a4ae", group="gExp"];
  browser [label=<<b>Your browser</b>>,          fillcolor="#eceff1", color="#90a4ae", group="gView"];
  llm     [label=<<b>AI assistant</b>>,           fillcolor="#eceff1", color="#90a4ae"];

  // ---- Layout: rows keep the picture compact; invisible edges pin the
  //      left-to-right order within each row --------------------------
  // view sits on the far right (next to the recording it opens); the
  // other three are the expose/capture subcommands.
  {rank=same; exporter; record; hindsight; view; exporter -> record -> hindsight -> view [style=invis];}
  {rank=same; grafana; recording; browser; grafana -> recording -> browser [style=invis];}
  // mcp and parquet sit side by side directly under the recording, with
  // the AI assistant to the left of mcp.
  {rank=same; llm; mcp; pqtools; llm -> mcp -> pqtools [style=invis];}

  // ---- Collect ----------------------------------------------------------
  system -> agent [label="collect"];

  // ---- Live from the agent ---------------------------------------------
  agent -> exporter  [label="expose"];
  agent -> view      [label="watch live"];
  agent -> record    [label="save"];
  agent -> hindsight [label="always-on buffer"];

  exporter -> grafana [label="scrape", weight=10];

  // ---- Produce a recording ---------------------------------------------
  record    -> recording;
  hindsight -> recording [label="dump on trigger", weight=10];

  // ---- Do things with the recording ------------------------------------
  recording -> view    [label="open recording", color="#8d6e63", constraint=false];
  recording -> mcp     [label="analyze", color="#8d6e63"];
  recording -> pqtools [label="manage",  color="#8d6e63"];

  // ---- Outcomes ---------------------------------------------------------
  view -> browser [dir=both, weight=10];
  mcp  -> llm     [label="ask", dir=both, constraint=false];
}
