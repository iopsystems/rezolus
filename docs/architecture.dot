// Rezolus component & data-flow diagram
//
// Render:  dot -Tsvg docs/architecture.dot -o docs/architecture.svg
//          dot -Tpng docs/architecture.dot -o docs/architecture.png
//
// A single `rezolus` binary provides every role shown in the middle band.
// Arrows show how data flows between what Rezolus observes, the roles that
// process it, the artifacts they produce, and the external systems that
// consume them.

digraph rezolus {
  rankdir=LR;
  fontname="Helvetica";
  labelloc="t";
  label="Rezolus — components & data flow (one binary, many roles)";
  fontsize=18;
  nodesep=0.35;
  ranksep=1.0;
  bgcolor="white";

  node [fontname="Helvetica", fontsize=11, style="filled", penwidth=1.2];
  edge [fontname="Helvetica", fontsize=9, color="#555555"];

  // ---- What Rezolus observes -------------------------------------------
  subgraph cluster_sources {
    label="Observed systems";
    style="rounded,filled";
    color="#c8ddb0";
    fillcolor="#eef5e3";
    fontname="Helvetica"; fontsize=13;

    kernel   [label="Kernel & CPU\n(eBPF, perf events)\nscheduler · syscalls · block I/O\nTCP/network · cache · TLB", shape=box, fillcolor="#dcedc8"];
    gpu      [label="GPU\n(NVIDIA NVML/GPM,\nApple on macOS)", shape=box, fillcolor="#dcedc8"];
    services [label="Services & inference\n(vLLM · SGLang · Valkey)\nPrometheus endpoints", shape=box, fillcolor="#dcedc8"];
  }

  // ---- The single binary and its roles ---------------------------------
  subgraph cluster_binary {
    label="rezolus (single binary)";
    style="rounded,filled";
    color="#7aa7d9";
    fillcolor="#e9f1fb";
    fontname="Helvetica"; fontsize=14;

    agent     [label="Agent\ncollects via samplers,\nserves msgpack over HTTP\n(:4241)", shape=box, fillcolor="#bbdefb"];
    exporter  [label="Exporter\nsummarizes histograms →\nPrometheus exposition", shape=box, fillcolor="#bbdefb"];
    recorder  [label="Recorder\nsnapshots → Parquet\n(on demand)", shape=box, fillcolor="#bbdefb"];
    hindsight [label="Hindsight\non-disk ring buffer,\ndump after an incident", shape=box, fillcolor="#bbdefb"];
    viewer    [label="Viewer\nweb dashboard,\nin-browser PromQL (WASM)", shape=box, fillcolor="#bbdefb"];
    pqtools   [label="Parquet Tools\nmetadata · annotate · combine", shape=box, fillcolor="#bbdefb"];
    mcp       [label="MCP Server\nPromQL · anomaly detection ·\ncorrelation for LLMs", shape=box, fillcolor="#bbdefb"];
  }

  // ---- Artifacts & external consumers ----------------------------------
  subgraph cluster_out {
    label="Artifacts & consumers";
    style="rounded,filled";
    color="#e6c48a";
    fillcolor="#fbf3e2";
    fontname="Helvetica"; fontsize=13;

    parquet    [label="Parquet files\n(recordings)", shape=cylinder, fillcolor="#ffe0b2"];
    prometheus [label="Prometheus / Grafana", shape=box, fillcolor="#ffe0b2"];
    browser    [label="Browser", shape=box, fillcolor="#ffe0b2"];
    llm        [label="LLM assistant", shape=box, fillcolor="#ffe0b2"];
  }

  // ---- Collection: sources feed the agent ------------------------------
  kernel   -> agent [label="in-kernel\nhistograms"];
  gpu      -> agent;
  services -> recorder [label="scrape\nPrometheus", style=dashed];

  // ---- Agent's msgpack snapshot fans out to every reader ---------------
  agent -> exporter  [label="msgpack\n/metrics/binary", color="#1565c0", penwidth=1.6];
  agent -> recorder  [label="msgpack", color="#1565c0", penwidth=1.6];
  agent -> hindsight [label="msgpack", color="#1565c0", penwidth=1.6];
  agent -> viewer    [label="msgpack (live)", color="#1565c0", penwidth=1.6];

  // ---- Producing artifacts ---------------------------------------------
  exporter  -> prometheus [label="scrape", style=dashed];
  recorder  -> parquet;
  hindsight -> parquet [label="snapshot\non trigger"];

  // ---- Consuming artifacts (back-edges; unconstrained so they route
  //      cleanly without distorting the left-to-right ranks) ------------
  parquet -> viewer  [color="#8d6e63", constraint=false];
  parquet -> mcp     [color="#8d6e63", constraint=false];
  parquet -> pqtools [label="inspect · annotate ·\ncombine", color="#8d6e63", constraint=false];

  // ---- Human / machine consumers ---------------------------------------
  viewer -> browser [label="dashboard", dir=both];
  mcp    -> llm [label="MCP / stdio", dir=both];
}
