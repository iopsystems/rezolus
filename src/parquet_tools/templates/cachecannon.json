{
  "service_name": "cachecannon",
  "service_metadata": {},
  "slo": null,
  "kpis": [
    {
      "role": "load",
      "title": "Request Rate",
      "query": "sum(irate(requests_sent[5s]))",
      "type": "delta_counter",
      "unit_system": "rate"
    },
    {
      "role": "load",
      "title": "Target Rate",
      "query": "target_rate",
      "type": "gauge",
      "unit_system": "count"
    },
    {
      "role": "throughput",
      "title": "Response Rate",
      "query": "sum(irate(responses_received[5s]))",
      "type": "delta_counter",
      "unit_system": "rate",
      "denominator": true
    },
    {
      "role": "throughput",
      "title": "Bytes Received Rate",
      "query": "sum(irate(bytes_rx[5s]))",
      "type": "delta_counter",
      "unit_system": "data_rate"
    },
    {
      "role": "latency",
      "title": "Response Latency",
      "query": "response_latency",
      "type": "histogram",
      "subtype": "percentiles",
      "unit_system": "time"
    },
    {
      "role": "error",
      "title": "Error Rate",
      "query": "sum(irate(request_errors[5s]))",
      "type": "delta_counter",
      "unit_system": "rate"
    },
    {
      "role": "error",
      "title": "Connection Failure Rate",
      "query": "sum(irate(connections_failed[5s]))",
      "type": "delta_counter",
      "unit_system": "rate"
    }
  ]
}
