---
source: crates/dashboard/tests/sql_snapshots.rs
assertion_line: 121
expression: "sql::cgroup_irate_by_name(\"cgroup_cpu_usage\", CgroupSide::Individual, None,)"
---
WITH unp AS (
              UNPIVOT (SELECT timestamp, COLUMNS('^cgroup_cpu_usage(/[^:]+)?$') FROM _src)
                  ON COLUMNS('^cgroup_cpu_usage(/[^:]+)?$') INTO NAME col VALUE v
           ),
           joined AS (
              SELECT u.timestamp, idx.name, u.col, u.v
              FROM unp u JOIN _cgroup_index idx
                  ON idx.column_name = u.col AND idx.metric = 'cgroup_cpu_usage'
              WHERE idx.name IN __SELECTED_CGROUPS__
           ),
           rates AS (
              SELECT timestamp, name,
                     irate_lag(
                         v,
                         LAG(v) OVER (PARTITION BY col ORDER BY timestamp),
                         timestamp - LAG(timestamp) OVER (PARTITION BY col ORDER BY timestamp)
                     ) AS rate
              FROM joined
           )
           SELECT timestamp::DOUBLE/1e9 AS t, name, SUM(rate) AS v
           FROM rates
           GROUP BY timestamp, name
