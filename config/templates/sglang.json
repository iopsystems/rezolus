{
  "service_name": "sglang",
  "service_metadata": {},
  "slo": null,
  "kpis": [
    {
      "role": "requests",
      "title": "Requests Running",
      "query": "sglang_num_running_reqs{source=\"sglang\"}",
      "type": "gauge",
      "unit_system": "count"
    },
    {
      "role": "requests",
      "title": "Request Rate",
      "query": "sum(irate(sglang_num_requests_total{source=\"sglang\"}[5s]))",
      "type": "delta_counter",
      "unit_system": "rate"
    },
    {
      "role": "requests",
      "title": "Request Completion Rate",
      "query": "sum(irate(sglang_num_requests_total{source=\"sglang\"}[5s])) - sum(irate(sglang_num_aborted_requests_total{source=\"sglang\"}[5s]))",
      "type": "delta_counter",
      "unit_system": "rate"
    },
    {
      "role": "requests",
      "title": "Abort Rate",
      "query": "sum(irate(sglang_num_aborted_requests_total{source=\"sglang\"}[5s]))",
      "type": "delta_counter",
      "unit_system": "rate"
    },
    {
      "role": "requests",
      "title": "Paused Requests",
      "query": "sglang_num_paused_reqs{source=\"sglang\"}",
      "type": "gauge",
      "unit_system": "count"
    },
    {
      "role": "requests",
      "title": "Retracted Requests",
      "query": "sglang_num_retracted_reqs{source=\"sglang\"}",
      "type": "gauge",
      "unit_system": "count"
    },
    {
      "role": "tokens",
      "title": "Prompt Token Rate",
      "query": "sum(irate(sglang_prompt_tokens_total{source=\"sglang\"}[5s]))",
      "type": "delta_counter",
      "unit_system": "rate"
    },
    {
      "role": "tokens",
      "title": "Generation Token Rate",
      "query": "sum(irate(sglang_generation_tokens_total{source=\"sglang\"}[5s]))",
      "type": "delta_counter",
      "unit_system": "rate",
      "denominator": true
    },
    {
      "role": "tokens",
      "title": "Realtime Token Rate (Prefill Compute)",
      "query": "sum(irate(sglang_realtime_tokens_total{source=\"sglang\",mode=\"prefill_compute\"}[5s]))",
      "type": "delta_counter",
      "unit_system": "rate"
    },
    {
      "role": "tokens",
      "title": "Realtime Token Rate (Prefill Cache)",
      "query": "sum(irate(sglang_realtime_tokens_total{source=\"sglang\",mode=\"prefill_cache\"}[5s]))",
      "type": "delta_counter",
      "unit_system": "rate"
    },
    {
      "role": "tokens",
      "title": "Realtime Token Rate (Decode)",
      "query": "sum(irate(sglang_realtime_tokens_total{source=\"sglang\",mode=\"decode\"}[5s]))",
      "type": "delta_counter",
      "unit_system": "rate"
    },
    {
      "role": "latency",
      "title": "Time to First Token (TTFT)",
      "query": "sglang_time_to_first_token_seconds{source=\"sglang\"}",
      "type": "histogram",
      "subtype": "percentiles",
      "percentiles": [0.5, 0.95],
      "unit_system": "time"
    },
    {
      "role": "latency",
      "title": "Inter-Token Latency (ITL)",
      "query": "sglang_inter_token_latency_seconds{source=\"sglang\"}",
      "type": "histogram",
      "subtype": "percentiles",
      "percentiles": [0.5, 0.95],
      "unit_system": "time"
    },
    {
      "role": "latency",
      "title": "End-to-End Request Latency",
      "query": "sglang_e2e_request_latency_seconds{source=\"sglang\"}",
      "type": "histogram",
      "subtype": "percentiles",
      "percentiles": [0.5, 0.95],
      "unit_system": "time"
    },
    {
      "role": "queueing",
      "title": "Requests Waiting",
      "query": "sglang_num_queue_reqs{source=\"sglang\"}",
      "type": "gauge",
      "unit_system": "count"
    },
    {
      "role": "queueing",
      "title": "Queue Time",
      "query": "sglang_queue_time_seconds{source=\"sglang\"}",
      "type": "histogram",
      "subtype": "percentiles",
      "percentiles": [0.5, 0.95],
      "unit_system": "time"
    },
    {
      "role": "queueing",
      "title": "Prefill Prealloc Queue Requests",
      "query": "sglang_num_prefill_prealloc_queue_reqs{source=\"sglang\"}",
      "type": "gauge",
      "unit_system": "count"
    },
    {
      "role": "queueing",
      "title": "Prefill Inflight Queue Requests",
      "query": "sglang_num_prefill_inflight_queue_reqs{source=\"sglang\"}",
      "type": "gauge",
      "unit_system": "count"
    },
    {
      "role": "queueing",
      "title": "Decode Prealloc Queue Requests",
      "query": "sglang_num_decode_prealloc_queue_reqs{source=\"sglang\"}",
      "type": "gauge",
      "unit_system": "count"
    },
    {
      "role": "queueing",
      "title": "Decode Transfer Queue Requests",
      "query": "sglang_num_decode_transfer_queue_reqs{source=\"sglang\"}",
      "type": "gauge",
      "unit_system": "count"
    },
    {
      "role": "cache",
      "title": "Cache Hit Rate",
      "query": "sglang_cache_hit_rate{source=\"sglang\"}",
      "type": "gauge",
      "unit_system": "percentage"
    },
    {
      "role": "cache",
      "title": "Cached Token Rate",
      "query": "sum(irate(sglang_cached_tokens_total{source=\"sglang\"}[5s]))",
      "type": "delta_counter",
      "unit_system": "rate"
    },
    {
      "role": "cache",
      "title": "Evicted Token Rate",
      "query": "sum(irate(sglang_evicted_tokens_total{source=\"sglang\"}[5s]))",
      "type": "delta_counter",
      "unit_system": "rate"
    },
    {
      "role": "speculative",
      "title": "Speculative Accept Rate",
      "query": "sglang_spec_accept_rate{source=\"sglang\"}",
      "type": "gauge",
      "unit_system": "percentage"
    },
    {
      "role": "speculative",
      "title": "Speculative Accept Length",
      "query": "sglang_spec_accept_length{source=\"sglang\"}",
      "type": "gauge",
      "unit_system": "count"
    },
    {
      "role": "gpu",
      "title": "Estimated FLOPS per GPU",
      "query": "sum(irate(sglang_estimated_flops_per_gpu_total{source=\"sglang\"}[5s]))",
      "type": "delta_counter",
      "unit_system": "rate"
    },
    {
      "role": "gpu",
      "title": "Estimated Memory Read Bandwidth per GPU",
      "query": "sum(irate(sglang_estimated_read_bytes_per_gpu_total{source=\"sglang\"}[5s]))",
      "type": "delta_counter",
      "unit_system": "datarate"
    },
    {
      "role": "gpu",
      "title": "Estimated Memory Write Bandwidth per GPU",
      "query": "sum(irate(sglang_estimated_write_bytes_per_gpu_total{source=\"sglang\"}[5s]))",
      "type": "delta_counter",
      "unit_system": "datarate"
    }
  ]
}
